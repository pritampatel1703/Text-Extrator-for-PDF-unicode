# ============================================
# PDF Text Extraction & Global Search Platform
# Environment Configuration
# ============================================

# Application
APP_NAME=pdf-search-platform
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
API_PREFIX=/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pdf_platform
POSTGRES_USER=pdf_admin
POSTGRES_PASSWORD=pdf_secure_password_2024
DATABASE_URL=postgresql+asyncpg://pdf_admin:pdf_secure_password_2024@postgres:5432/pdf_platform

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=pdf_pages
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# File Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=200
ALLOWED_EXTENSIONS=.pdf

# OCR Configuration
OCR_ENGINE=paddleocr
TESSERACT_PATH=/usr/bin/tesseract
PADDLEOCR_LANG=en
OCR_DPI=300

# AI / Embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32
ENABLE_SEMANTIC_SEARCH=true

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
